---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: 'Full Skin System',
    description: 'Every pixel is customizable. Skins control colors, fonts, panels, animations, and vibes. Ship your own or browse the community gallery.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>`,
    title: 'Resizable Panels',
    description: 'Intel, signal, and telemetry panels dock around the terminal. Drag to resize. Collapse what you don\'t need. Every layout persists.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
    title: 'Built-in Music Player',
    description: 'Stream from Spotify, Apple Music, or your local library. Visualizer reacts to audio. Album art in the vibes bar. Code with a soundtrack.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>`,
    title: 'Live2D Companions',
    description: 'Desk pets that react to your shell state. Idle animations, typing reactions, and tool-use celebrations. Currently: TypeCat.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: 'Real-time Telemetry',
    description: 'Model, context usage, token counts, cost, and session stats — all live from Claude Code\'s status line. Always know where you stand.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    title: 'Hook Events',
    description: 'Captures Claude Code hook events — tool calls, permissions, errors. The event stream feeds panels so you always see what\'s happening.',
  },
];
---

<section id="features" class="section">
  <div class="container">
    <div class="section-header">
      <span class="badge">Features</span>
      <h2>Everything around the terminal</h2>
      <p>Moltamp doesn't replace Claude Code — it gives it a cockpit. Every panel, widget, and pixel serves the workflow.</p>
    </div>

    <div class="features-grid">
      {features.map((f) => (
        <div class="card feature-card">
          <div class="feature-icon" set:html={f.icon} />
          <h3>{f.title}</h3>
          <p>{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .feature-card {
    padding: 28px;
  }

  .feature-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    background: var(--accent-subtle);
    color: var(--accent);
    margin-bottom: 20px;
  }

  .feature-card h3 {
    margin-bottom: 10px;
    font-size: 1.1rem;
  }

  .feature-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
