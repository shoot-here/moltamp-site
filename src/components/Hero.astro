---
import InteractiveDemo from './InteractiveDemo.astro';
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <img src="/images/logo.png" alt="" class="hero-logo" width="88" height="88" />

      <span class="badge">
        <span class="badge-dot"></span>
        Now in public beta
      </span>

      <h1>
        Skin your<br />
        <span class="gradient-text">AI terminal</span>.
      </h1>

      <p class="hero-sub">
        MOLTamp wraps your AI terminal in a cockpit UI with skins, panels, a music player,
        Live2D desk pets, and real-time telemetry. The vibes are the feature.
      </p>

      <div class="hero-download">
        <a href="#pricing" class="btn btn-primary btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download for Mac
        </a>
      </div>

      <div class="hero-platform">
        <svg class="apple-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <span>Available on macOS</span>
        <span class="platform-divider"></span>
        <span class="platform-soon">Windows + Linux coming soon</span>
      </div>
    </div>

    <!-- Interactive app demo -->
    <div class="hero-demo fade-in">
      <InteractiveDemo />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: calc(var(--nav-height) + 80px) 0 60px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse, var(--accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .hero-logo {
    width: 88px;
    height: 88px;
    object-fit: contain;
    margin: 0 auto 20px;
    display: block;
    filter: drop-shadow(0 0 24px rgba(255, 80, 40, 0.3));
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  h1 {
    font-family: var(--font-heading);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin-top: 24px;
    margin-bottom: 24px;
    padding: 0 4px;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--accent), var(--accent-warm));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    color: var(--text-secondary);
    font-size: 1.2rem;
    max-width: 560px;
    margin: 0 auto 40px;
    line-height: 1.7;
  }

  .hero-download {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-lg {
    padding: 14px 32px;
    font-size: 1rem;
  }

  /* Platform badge */
  .hero-platform {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .apple-icon {
    opacity: 0.7;
  }

  .platform-divider {
    width: 1px;
    height: 14px;
    background: var(--border-hover);
    margin: 0 4px;
  }

  .platform-soon {
    color: var(--text-dim);
  }

  /* Demo area */
  .hero-demo {
    margin-top: 64px;
    position: relative;
    z-index: 1;
  }
</style>
