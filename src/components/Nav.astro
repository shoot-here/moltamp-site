---
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">
      <img src="/images/logo.png" alt="MOLTamp" class="logo-img" width="28" height="28" />
      <span class="logo-text">MOLTamp</span>
    </a>

    <div class="nav-links" id="nav-links">
      <a href="/#features">Features</a>
      <a href="/skins">Skins</a>
      <a href="/widgets">Widgets</a>
      <a href="/#pricing">Pricing</a>
      <a href="/roadmap">Roadmap</a>
      <a href="/#faq">FAQ</a>
    </div>

    <div class="nav-actions">
      <a href="https://x.com/moltamp" target="_blank" rel="noopener" class="nav-social" aria-label="Follow on X">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <div class="nav-github-wrap" id="github-wrap">
        <button class="nav-github" aria-label="GitHub repos" id="github-toggle">
          <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        </button>
        <div class="github-dropdown" id="github-dropdown">
          <a href="https://github.com/shoot-here/moltamp-skins" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            Skins
          </a>
          <a href="https://github.com/shoot-here/moltamp-widgets" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            Widgets
          </a>
        </div>
      </div>
      <a href="/login" class="btn btn-secondary btn-sm nav-auth-btn" id="nav-auth">Login</a>
      <a href="#pricing" class="btn btn-primary btn-sm nav-download">Download</a>
      <button class="nav-burger" id="nav-burger" aria-label="Toggle navigation" aria-expanded="false">
        <span class="burger-line"></span>
        <span class="burger-line"></span>
        <span class="burger-line"></span>
      </button>
    </div>
  </div>
</nav>

<script>
  const burger = document.getElementById('nav-burger');
  const links = document.getElementById('nav-links');

  burger?.addEventListener('click', () => {
    const expanded = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!expanded));
    links?.classList.toggle('open');
    burger.classList.toggle('open');
  });

  // Close mobile menu when a link is clicked
  links?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      links.classList.remove('open');
      burger?.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
    });
  });

  // GitHub dropdown
  const ghToggle = document.getElementById('github-toggle');
  const ghDropdown = document.getElementById('github-dropdown');
  const ghWrap = document.getElementById('github-wrap');

  ghToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    ghDropdown?.classList.toggle('open');
  });

  document.addEventListener('click', (e) => {
    if (!ghWrap?.contains(e.target as Node)) {
      ghDropdown?.classList.remove('open');
    }
  });

  // Auth state — swap Login for Dashboard
  const navAuth = document.getElementById('nav-auth') as HTMLAnchorElement;
  fetch('/api/auth/me').then(r => r.ok ? r.json() : null).then(d => {
    if (d && navAuth) {
      navAuth.href = '/dashboard';
      navAuth.textContent = 'Dashboard';
      navAuth.classList.add('authed');
      navAuth.classList.remove('btn-secondary');
    }
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    background: rgba(8, 8, 10, 0.8);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .nav-logo:hover {
    color: var(--text-primary);
  }

  .logo-img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .logo-text {
    font-family: var(--font-mono);
    letter-spacing: -0.03em;
  }

  .nav-links {
    display: flex;
    gap: 32px;
  }

  .nav-links a {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 450;
  }

  .nav-links a:hover {
    color: var(--text-primary);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav-auth-btn {
    font-size: 0.85rem;
    font-weight: 500;
    padding: 8px 18px;
  }

  .nav-auth-btn.authed {
    border-color: var(--accent);
    color: var(--accent);
  }

  .nav-social {
    color: #888;
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .nav-social:hover {
    color: #fff;
  }

  .nav-github-wrap {
    position: relative;
  }

  .nav-github {
    color: #888;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
  }
  .nav-github:hover {
    color: #fff;
  }

  .github-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: rgba(18, 18, 22, 0.95);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 4px;
    min-width: 150px;
    z-index: 200;
  }

  .github-dropdown.open {
    display: flex;
    flex-direction: column;
  }

  .github-dropdown a {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 450;
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
  }

  .github-dropdown a:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-primary);
  }

  .btn-sm {
    padding: 8px 20px;
    font-size: 0.85rem;
  }

  /* Hamburger */
  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .burger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--text-primary);
    border-radius: 1px;
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .nav-burger.open .burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-burger.open .burger-line:nth-child(2) {
    opacity: 0;
  }

  .nav-burger.open .burger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
      position: absolute;
      top: var(--nav-height);
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background: rgba(8, 8, 10, 0.95);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      padding: 8px 0;
    }

    .nav-links.open {
      display: flex;
    }

    .nav-links a {
      padding: 14px 24px;
      font-size: 1rem;
    }

    .nav-links a:hover {
      background: var(--bg-card);
    }

    .nav-download {
      display: none;
    }

    .nav-burger {
      display: flex;
    }
  }
</style>
