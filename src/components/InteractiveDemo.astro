<script>
  function initDemo() {
    const root = document.getElementById('moltamp-demo');
    if (!root) return;

    // Clock
    const clockEl = document.getElementById('demo-clock');
    const dateEl = document.getElementById('demo-date');
    function updateClock() {
      const now = new Date();
      const h = String(now.getHours()).padStart(2, '0');
      const m = String(now.getMinutes()).padStart(2, '0');
      const s = String(now.getSeconds()).padStart(2, '0');
      if (clockEl) clockEl.textContent = h + ':' + m + ':' + s;
      if (dateEl) {
        const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
        const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        dateEl.textContent = days[now.getDay()] + ', ' + months[now.getMonth()] + ' ' + now.getDate();
      }
    }
    updateClock();
    setInterval(updateClock, 1000);

    // Tab switching (works for both left and right panels)
    root.querySelectorAll('.panel-tabs').forEach(function(tabBar) {
      const panel = tabBar.getAttribute('data-panel');
      const contentArea = root.querySelector('.panel-content[data-panel="' + panel + '"]');
      tabBar.querySelectorAll('.ptab').forEach(function(tab) {
        tab.addEventListener('click', function() {
          const target = tab.getAttribute('data-tab');
          // Deactivate all tabs in this bar
          tabBar.querySelectorAll('.ptab').forEach(function(t) { t.classList.remove('active'); });
          tab.classList.add('active');
          // Show matching content
          if (contentArea) {
            contentArea.querySelectorAll('.pcontent').forEach(function(c) { c.classList.remove('active'); });
            var targetContent = contentArea.querySelector('.pcontent[data-tab="' + target + '"]');
            if (targetContent) targetContent.classList.add('active');
          }
        });
      });
    });

    // Widget collapse/expand
    root.querySelectorAll('.widget-hdr[data-collapse]').forEach(function(hdr) {
      hdr.addEventListener('click', function() {
        var id = hdr.getAttribute('data-collapse');
        var body = document.getElementById(id + '-body');
        if (!body) return;
        hdr.classList.toggle('collapsed');
        body.classList.toggle('collapsed');
      });
    });

    // Weather tabs (simple toggle)
    root.querySelectorAll('.wtab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        root.querySelectorAll('.wtab').forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
      });
    });

    // Session tab switching (Claude / Codex)
    root.querySelectorAll('.m-session-tab[data-session]').forEach(function(tab) {
      tab.addEventListener('click', function() {
        var session = tab.getAttribute('data-session');
        root.querySelectorAll('.m-session-tab[data-session]').forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        root.querySelectorAll('.term-session').forEach(function(s) { s.classList.remove('active'); });
        var target = root.querySelector('.term-session[data-session="' + session + '"]');
        if (target) target.classList.add('active');
      });
    });
  }

  // Run on load and on Astro page navigation
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDemo);
  } else {
    initDemo();
  }
  document.addEventListener('astro:after-swap', initDemo);
</script>
