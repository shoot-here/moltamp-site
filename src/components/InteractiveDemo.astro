---
---

<div class="demo-wrap">
  <div class="glow-border">
    <div class="m" id="moltamp-demo">

      <!-- Title Bar -->
      <div class="m-titlebar">
        <div class="m-titlebar-left">
          <span class="dot dot-r"></span><span class="dot dot-y"></span><span class="dot dot-g"></span>
          <span class="m-title">&#9889;MOLTamp</span>
        </div>
        <div class="m-titlebar-right">
          <span class="tb-btn">&#8211;</span>
          <span class="tb-btn">&#9678;</span>
          <span class="tb-btn">+</span>
          <span class="tb-btn">Aa</span>
          <span class="tb-btn">&#9650;&#9664;&#9654;&#9660;</span>
          <span class="tb-btn">&#9881;</span>
        </div>
      </div>

      <!-- Vibes Banner -->
      <div class="m-vibes">
        <div class="vibes-gradient"></div>
        <div class="vibes-scanlines"></div>
      </div>

      <!-- Session Tabs -->
      <div class="m-tabs-bar">
        <div class="m-session-tab active" data-session="claude">
          <span class="tab-icon">&#9670;</span> Claude Code moltamp
          <span class="tab-close">&times;</span>
        </div>
        <div class="m-session-tab" data-session="codex">
          <span class="tab-icon" style="color:#00ff41;">&#9679;</span> Codex CLI api-server
          <span class="tab-close">&times;</span>
        </div>
        <div class="m-session-tab add-tab">+</div>
      </div>

      <!-- Deck: Left | Terminal | Right -->
      <div class="m-deck">

        <!-- Left Panel -->
        <div class="m-panel-left">
          <div class="panel-tabs" data-panel="left">
            <button class="ptab" data-tab="log">LOG <span class="ptab-badge">68</span></button>
            <button class="ptab" data-tab="files">FILES</button>
            <button class="ptab active" data-tab="agents">AGENTS</button>
            <button class="ptab" data-tab="git">GIT <span class="ptab-badge">3</span></button>
          </div>
          <div class="panel-content" data-panel="left">
            <!-- LOG -->
            <div class="pcontent" data-tab="log">
              <div class="log-entry"><span class="log-ts">14:52:01</span> Tool: Read App.tsx</div>
              <div class="log-entry"><span class="log-ts">14:52:03</span> Thinking...</div>
              <div class="log-entry"><span class="log-ts">14:52:08</span> Tool: Edit main.js</div>
              <div class="log-entry"><span class="log-ts">14:52:12</span> Tool: Bash npm run build</div>
              <div class="log-entry"><span class="log-ts">14:52:18</span> Response complete</div>
              <div class="log-entry"><span class="log-ts">14:53:01</span> Tool: Read theme.css</div>
              <div class="log-entry"><span class="log-ts">14:53:04</span> Tool: Grep "accent"</div>
              <div class="log-entry"><span class="log-ts">14:53:09</span> Tool: Edit theme.css</div>
              <div class="log-entry"><span class="log-ts">14:53:15</span> Tool: Read file.tsx</div>
              <div class="log-entry"><span class="log-ts">14:53:22</span> Thinking...</div>
            </div>
            <!-- FILES -->
            <div class="pcontent" data-tab="files">
              <div class="file-tree">
                <div class="ft-dir open"><span class="ft-toggle">&#9660;</span> moltamp/</div>
                <div class="ft-children">
                  <div class="ft-dir open"><span class="ft-toggle">&#9660;</span> src/</div>
                  <div class="ft-children">
                    <div class="ft-file">App.tsx</div>
                    <div class="ft-file">main.ts</div>
                    <div class="ft-dir"><span class="ft-toggle">&#9654;</span> components/</div>
                    <div class="ft-dir"><span class="ft-toggle">&#9654;</span> stores/</div>
                    <div class="ft-dir"><span class="ft-toggle">&#9654;</span> hooks/</div>
                  </div>
                  <div class="ft-dir"><span class="ft-toggle">&#9654;</span> electron/</div>
                  <div class="ft-dir open"><span class="ft-toggle">&#9660;</span> skins/</div>
                  <div class="ft-children">
                    <div class="ft-dir"><span class="ft-toggle">&#9654;</span> neon-horizon/</div>
                    <div class="ft-dir"><span class="ft-toggle">&#9654;</span> phosphor/</div>
                  </div>
                  <div class="ft-file">package.json</div>
                  <div class="ft-file">vite.config.ts</div>
                </div>
              </div>
            </div>
            <!-- AGENTS -->
            <div class="pcontent active" data-tab="agents">
              <div class="agents-header">AGENTS <span class="agents-status">IDLE</span></div>
              <div class="agents-count">0 TOTAL</div>
              <div class="agents-empty">No agents spawned yet</div>
            </div>
            <!-- GIT -->
            <div class="pcontent" data-tab="git">
              <div class="git-branch">&#9752; main</div>
              <div class="git-files">
                <div class="git-file"><span class="git-m">M</span> theme.css</div>
                <div class="git-file"><span class="git-m">M</span> App.tsx</div>
                <div class="git-file"><span class="git-a">A</span> demo.astro</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Terminal -->
        <div class="m-terminal">
          <!-- Claude session -->
          <div class="term-session active" data-session="claude">
            <div class="term-body">
              <div class="term-header">
                <span class="term-block b1"></span><span class="term-block b2"></span><span class="term-block b3"></span><span class="term-block b4"></span><span class="term-block b5"></span>
              </div>
              <div class="term-line t-bright">Claude Code v2.1.89</div>
              <div class="term-line t-dim">Opus 4.6 (1M context) &mdash; resume conversation</div>
              <div class="term-line t-dim">cwd: ~/Desktop/Claude/moltamp</div>
              <div class="term-sep"></div>

              <div class="term-user"><span class="prompt-arrow">&gt;</span> add a weather widget to the right panel</div>
              <div class="term-sep"></div>

              <div class="term-assistant">
                <div class="term-line t-dim">I'll add a weather widget. Let me check the existing panel structure first.</div>
              </div>

              <div class="term-tool">
                <span class="tool-icon">&#9654;</span>
                <span class="tool-name">Read</span>
                <span class="tool-path">src/components/panels/SignalPanel.tsx</span>
              </div>
              <div class="term-tool">
                <span class="tool-icon">&#9654;</span>
                <span class="tool-name">Read</span>
                <span class="tool-path">src/stores/skin-store.ts</span>
              </div>

              <div class="term-assistant">
                <div class="term-line t-dim">Got it. I'll create the WeatherWidget component and register it in the tab map.</div>
              </div>

              <div class="term-tool">
                <span class="tool-icon" style="color:var(--green);">&#9654;</span>
                <span class="tool-name" style="color:var(--green);">Write</span>
                <span class="tool-path">src/components/panels/WeatherWidget.tsx</span>
                <span class="tool-result">+87 lines</span>
              </div>
              <div class="term-tool">
                <span class="tool-icon" style="color:var(--yellow);">&#9654;</span>
                <span class="tool-name" style="color:var(--yellow);">Edit</span>
                <span class="tool-path">src/components/panels/tab-registry.ts</span>
                <span class="tool-result">3 changes</span>
              </div>
              <div class="term-tool">
                <span class="tool-icon">&#9654;</span>
                <span class="tool-name">Bash</span>
                <span class="tool-path">npm run build</span>
                <span class="tool-result" style="color:var(--green);">&#10003; passed</span>
              </div>

              <div class="term-sep"></div>
              <div class="term-assistant">
                <div class="term-line t-dim">Weather widget added. It shows current conditions and a 3-day forecast. Uses the free Open-Meteo API &mdash; no key needed. Refresh to see it in the Widgets tab.</div>
              </div>
              <div class="term-sep"></div>
              <div class="term-prompt"><span class="prompt-arrow">&gt;</span><span class="cursor">_</span></div>
            </div>
            <div class="term-footer">
              <span class="tf-model">[Opus 4.6 (1M context)]</span>
              <span class="tf-ctx">12% context</span>
              <span class="tf-perm">&gt;&gt; bypass permissions on <span class="tf-cycle">(shift+tab to cycle)</span></span>
            </div>
            <div class="term-companion">{"{"}<span>*&gt; Gnarl</span></div>
          </div>

          <!-- Codex session -->
          <div class="term-session" data-session="codex">
            <div class="term-body">
              <div class="term-line t-green">Codex CLI v0.1.2</div>
              <div class="term-line t-dim">model: codex-1 &mdash; full auto</div>
              <div class="term-line t-dim">cwd: ~/projects/api-server</div>
              <div class="term-sep"></div>

              <div class="term-user"><span class="prompt-arrow" style="color:var(--green);">&gt;</span> fix the auth middleware — tokens expire but the refresh logic never fires</div>
              <div class="term-sep"></div>

              <div class="term-tool">
                <span class="tool-icon" style="color:var(--green);">&#9654;</span>
                <span class="tool-name">read</span>
                <span class="tool-path">src/middleware/auth.ts</span>
              </div>
              <div class="term-tool">
                <span class="tool-icon" style="color:var(--green);">&#9654;</span>
                <span class="tool-name">read</span>
                <span class="tool-path">src/services/token.ts</span>
              </div>

              <div class="term-assistant">
                <div class="term-line t-dim">Found it &mdash; the refresh check compares timestamps in seconds but the JWT exp is in milliseconds. Off by 1000x.</div>
              </div>

              <div class="term-tool">
                <span class="tool-icon" style="color:var(--yellow);">&#9654;</span>
                <span class="tool-name" style="color:var(--yellow);">patch</span>
                <span class="tool-path">src/middleware/auth.ts</span>
                <span class="tool-result">1 change</span>
              </div>
              <div class="term-tool">
                <span class="tool-icon" style="color:var(--green);">&#9654;</span>
                <span class="tool-name">shell</span>
                <span class="tool-path">npm test -- --grep "refresh"</span>
                <span class="tool-result" style="color:var(--green);">3 passed</span>
              </div>

              <div class="term-sep"></div>
              <div class="term-assistant">
                <div class="term-line t-dim">Fixed. Changed <span style="color:var(--red);">Date.now()</span> to <span style="color:var(--green);">Date.now() / 1000</span> in the expiry comparison. All refresh tests pass.</div>
              </div>
              <div class="term-sep"></div>
              <div class="term-prompt"><span class="prompt-arrow" style="color:var(--green);">&gt;</span><span class="cursor">_</span></div>
            </div>
            <div class="term-footer">
              <span class="tf-model" style="color:var(--green);">[codex-1]</span>
              <span class="tf-ctx">8% context</span>
              <span class="tf-perm">&gt;&gt; full auto <span class="tf-cycle">(shift+tab to cycle)</span></span>
            </div>
          </div>
        </div>

        <!-- Right Panel -->
        <div class="m-panel-right">
          <div class="panel-tabs" data-panel="right">
            <button class="ptab active" data-tab="widgets">WIDGETS</button>
            <button class="ptab" data-tab="media">MEDIA</button>
            <button class="ptab" data-tab="usage">USAGE</button>
          </div>
          <div class="panel-content scrollable" data-panel="right">
            <!-- WIDGETS -->
            <div class="pcontent active" data-tab="widgets">
              <!-- Clock -->
              <div class="widget">
                <div class="widget-hdr" data-collapse="clock"><span class="wh-arrow">&#9660;</span> CLOCK</div>
                <div class="widget-body" id="clock-body">
                  <div class="clock-time" id="demo-clock">00:00:00</div>
                  <div class="clock-date" id="demo-date">Thu, Apr 3</div>
                </div>
              </div>
              <!-- Session Timer -->
              <div class="widget">
                <div class="widget-hdr" data-collapse="session"><span class="wh-arrow">&#9660;</span> SESSION TIMER</div>
                <div class="widget-body" id="session-body">
                  <div class="session-row"><span>SESSION</span><span class="session-time">2:34</span></div>
                  <div class="progress-bar"><div class="progress-fill" style="width:38%"></div></div>
                </div>
              </div>
              <!-- System Monitor -->
              <div class="widget">
                <div class="widget-hdr" data-collapse="sysmon"><span class="wh-arrow">&#9660;</span> SYSTEM MONITOR</div>
                <div class="widget-body" id="sysmon-body">
                  <div class="sysmon-row">
                    <span class="sysmon-label">CPU (12c)</span><span class="sysmon-val">25.6%</span>
                  </div>
                  <div class="meter"><div class="meter-fill cyan" style="width:25.6%"></div></div>
                  <div class="sysmon-detail">Load: 3.88 &nbsp; Gib: 4.21</div>
                  <div class="sysmon-row" style="margin-top:6px;">
                    <span class="sysmon-label">MEM</span><span class="sysmon-val warn">97.3%</span>
                  </div>
                  <div class="meter"><div class="meter-fill pink" style="width:97.3%"></div></div>
                  <div class="sysmon-detail">31.1G used &middot; 32.0G total</div>
                </div>
              </div>
              <!-- Music Player -->
              <div class="widget">
                <div class="widget-hdr" data-collapse="music"><span class="wh-arrow">&#9660;</span> MUSIC</div>
                <div class="widget-body" id="music-body">
                  <div class="wgt-viz">
                    <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                    <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                    <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                    <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                    <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                    <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                    <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                    <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                  </div>
                  <div class="wgt-track">Kavinsky &mdash; Nightcall</div>
                  <div class="wgt-album">OutRun (2013)</div>
                  <div class="wgt-prog-wrap">
                    <div class="media-prog-bar"><div class="media-prog-fill" style="width:42%"></div></div>
                    <div class="media-times"><span>1:47</span><span>4:16</span></div>
                  </div>
                  <div class="wgt-controls">
                    <span class="mc-btn">&#9664;&#9664;</span>
                    <span class="mc-btn mc-play mc-playing">&#9646;&#9646;</span>
                    <span class="mc-btn">&#9654;&#9654;</span>
                  </div>
                </div>
              </div>
            </div>
            <!-- MEDIA -->
            <div class="pcontent" data-tab="media">
              <div class="media-player">
                <div class="media-viz" id="demo-viz">
                  <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                  <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                  <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                  <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                  <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                  <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                  <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                  <div class="viz-bar"></div><div class="viz-bar"></div><div class="viz-bar"></div>
                </div>
                <div class="media-track">Kavinsky &mdash; Nightcall</div>
                <div class="media-artist">OutRun (2013)</div>
                <div class="media-progress">
                  <div class="media-prog-bar"><div class="media-prog-fill" id="demo-prog"></div></div>
                  <div class="media-times"><span>1:47</span><span>4:16</span></div>
                </div>
                <div class="media-controls">
                  <span class="mc-btn">&#9664;&#9664;</span>
                  <span class="mc-btn mc-play mc-playing">&#9646;&#9646;</span>
                  <span class="mc-btn">&#9654;&#9654;</span>
                </div>
              </div>
            </div>
            <!-- USAGE -->
            <div class="pcontent" data-tab="usage">
              <div class="usage-section">
                <div class="usage-row"><span>Input</span><span>45.2K</span></div>
                <div class="meter"><div class="meter-fill cyan" style="width:45%"></div></div>
                <div class="usage-row"><span>Output</span><span>2.3K</span></div>
                <div class="meter"><div class="meter-fill cyan" style="width:8%"></div></div>
                <div class="usage-row"><span>Cache</span><span>12.1K</span></div>
                <div class="meter"><div class="meter-fill pink" style="width:22%"></div></div>
                <div class="usage-row" style="margin-top:10px;"><span>Cost</span><span class="t-accent">$0.42</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Ticker -->
      <div class="m-ticker">
        <div class="ticker-track">
          <span class="tk-item tk-green">&#9679; M1.0 8 KM SE OF EIELSON AFB, ALASKA</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-green">H $185.00 &#9650;1.3%</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-red">WH $98.00 &#9660;2.3%</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-red">SPY $565.00 &#9660;0.0%</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-green">QQQ $487.50 &#9650;0.8%</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-green">&#9679; M2.3 12 KM NW OF GEYSERVILLE, CA</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-green">AAPL $227.40 &#9650;0.5%</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-red">MSFT $418.10 &#9660;1.1%</span>
          <!-- duplicate for seamless loop -->
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-green">&#9679; M1.0 8 KM SE OF EIELSON AFB, ALASKA</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-green">H $185.00 &#9650;1.3%</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-red">WH $98.00 &#9660;2.3%</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-red">SPY $565.00 &#9660;0.0%</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-green">QQQ $487.50 &#9650;0.8%</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-green">&#9679; M2.3 12 KM NW OF GEYSERVILLE, CA</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-green">AAPL $227.40 &#9650;0.5%</span>
          <span class="tk-sep">&middot;</span>
          <span class="tk-item tk-red">MSFT $418.10 &#9660;1.1%</span>
        </div>
      </div>

      <!-- Status Bar -->
      <div class="m-statusbar">
        <div class="sb-left">
          <span class="sb-btn">&#9664;</span>
          <span class="sb-btn">&#9654;</span>
          <span class="sb-btn">&#9654;&#9654;</span>
        </div>
        <span class="sb-skin">neon-horizon</span>
        <span class="sb-path">~/desktop/claude/moltamp</span>
        <span class="sb-version">&#9889; MOLTamp v0.1.0</span>
      </div>

    </div>
  </div>
</div>

<style>
  /* ── Reset & Container ───────────────────────────────────── */
  .demo-wrap {
    --bg: #040810;
    --bg-card: #0a1420;
    --bg-surface: #0d1a2a;
    --txt: #c8e6ff;
    --txt-dim: #4a6a8a;
    --accent: #00ffff;
    --accent-warm: #ff1493;
    --border: rgba(0, 255, 255, 0.12);
    --green: #00ff41;
    --red: #ff3366;
    --yellow: #ffaa00;
    --pink: #ff00aa;
    --mono: 'JetBrains Mono', 'Fira Code', 'SF Mono', 'Menlo', monospace;

    max-width: 1100px;
    margin: 0 auto;
  }

  .glow-border {
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(0,255,255,0.3), rgba(255,0,170,0.3), rgba(0,255,255,0.3));
    box-shadow: 0 0 40px rgba(0,255,255,0.08), 0 0 80px rgba(255,0,170,0.04);
  }

  .m {
    background: var(--bg);
    border-radius: 11px;
    overflow: hidden;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--txt);
    display: flex;
    flex-direction: column;
    height: 700px;
    user-select: none;
    position: relative;
  }

  .m *, .m *::before, .m *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* ── Title Bar ───────────────────────────────────────────── */
  .m-titlebar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 12px;
    height: 38px;
    background: linear-gradient(180deg, #0c0028 0%, #0a0020 100%);
    border-bottom: 1px solid #1a0040;
    flex-shrink: 0;
    position: relative;
  }

  .m-titlebar::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--accent), var(--pink), var(--accent));
    opacity: 0.5;
  }

  .m-titlebar-left, .m-titlebar-right { display: flex; align-items: center; gap: 8px; }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }
  .m-title { color: var(--accent); font-size: 12px; font-weight: 600; margin-left: 6px; }
  .tb-btn { color: var(--txt-dim); font-size: 10px; cursor: default; }

  /* ── Vibes Banner ────────────────────────────────────────── */
  .m-vibes {
    height: 80px;
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
    border-bottom: 1px solid #1a0040;
  }

  .vibes-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      #1a0040 0%, #3d0066 15%, #ff00aa33 30%,
      #0a0020 45%, #00ffff15 55%, #3d0066 70%,
      #ff00aa22 85%, #0a0020 100%
    );
    background-size: 300% 300%;
    animation: vibes-shift 8s ease-in-out infinite;
  }

  @keyframes vibes-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .vibes-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
