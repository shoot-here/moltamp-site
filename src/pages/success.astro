---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Purchase Complete — MOLTamp">
  <Nav />
  <main class="success-page">
    <div class="container">
      <div class="success-card card">
        <div class="success-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>

        <h1>You're unlocked.</h1>
        <p class="success-desc">
          Thank you for supporting MOLTamp! Your license key has been sent to your email.
        </p>

        <div class="success-steps">
          <h3>Next steps:</h3>
          <ol>
            <li>Check your email for your license key</li>
            <li>Open MOLTamp and go to Settings</li>
            <li>Paste your license key and click Activate</li>
            <li>The nag popup is gone forever</li>
          </ol>
        </div>

        <div class="success-actions">
          <a href="/" class="btn btn-secondary">Back to home</a>
          <a href="mailto:support@moltamp.com" class="btn btn-secondary">Need help?</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .success-page {
    padding: calc(var(--nav-height) + 80px) 0 120px;
    min-height: 100vh;
  }

  .success-card {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
    padding: 48px 40px;
  }

  .success-icon {
    color: var(--color-success);
    margin-bottom: 24px;
  }

  .success-card h1 {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  .success-desc {
    color: var(--text-secondary);
    margin-bottom: 32px;
    font-size: 1.05rem;
  }

  .success-steps {
    text-align: left;
    padding: 24px;
    background: var(--bg-secondary);
    border-radius: var(--radius-sm);
    margin-bottom: 32px;
  }

  .success-steps h3 {
    font-size: 0.85rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 16px;
  }

  .success-steps ol {
    padding-left: 20px;
  }

  .success-steps li {
    padding: 6px 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .success-steps li::marker {
    color: var(--accent);
    font-weight: 600;
  }

  .success-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
  }
</style>
