---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="You're In — MOLTamp"
  description="Your MOLTamp license is ready. Check your email for your license key and activation instructions."
>
  <Nav />
  <main class="success-scene">
    <div class="scene-bg" aria-hidden="true">
      <div class="scene-glow scene-glow--green"></div>
      <div class="scene-grain"></div>
    </div>

    <div class="success-card">
      <div class="sc-bar">
        <div class="sc-dots"><i></i><i></i><i></i></div>
        <span class="sc-path">moltamp://success</span>
      </div>
      <div class="sc-body">
        <div class="sc-check" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>

        <h1>You're unlocked<span class="caret">_</span></h1>
        <p class="sc-sub">Your license key has been sent to your email. Check your inbox.</p>

        <div class="sc-steps">
          <div class="section-label">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            <span>Next steps</span>
          </div>
          <ol class="steps-list">
            <li><span class="step-num">1</span>Check your email for your license key</li>
            <li><span class="step-num">2</span>Open MOLTamp → Settings</li>
            <li><span class="step-num">3</span>Paste your key and click Activate</li>
            <li><span class="step-num">4</span>The nag popup is gone forever</li>
          </ol>
        </div>

        <div class="sc-community">
          <p>You can now <a href="/login">sign in to the community</a> to upload, share, and download skins.</p>
        </div>

        <div class="sc-actions">
          <a href="/" class="btn btn-secondary">Home</a>
          <a href="/skins" class="btn btn-primary">Browse Skins</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .success-scene {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(var(--nav-height) + 40px) 24px 60px;
    position: relative;
    overflow: hidden;
  }

  .scene-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
  }

  .scene-glow--green {
    position: absolute;
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(34, 197, 94, 0.08) 0%, transparent 70%);
  }

  .scene-grain {
    position: absolute;
    inset: 0;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px;
  }

  .success-card {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 500px;
    border-radius: 16px;
    overflow: hidden;
    background: rgba(14, 14, 18, 0.85);
    backdrop-filter: blur(24px) saturate(1.2);
    border: 1px solid rgba(34, 197, 94, 0.1);
    box-shadow: 0 0 0 1px rgba(0,0,0,0.3), 0 20px 60px rgba(0,0,0,0.5), 0 0 80px rgba(34,197,94,0.04);
    animation: card-in 0.8s ease-out both;
  }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(24px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .sc-bar {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    background: rgba(255,255,255,0.02);
  }

  .sc-dots { display: flex; gap: 6px; }
  .sc-dots i { width: 10px; height: 10px; border-radius: 50%; display: block; }
  .sc-dots i:nth-child(1) { background: #ff5f57; }
  .sc-dots i:nth-child(2) { background: #febc2e; }
  .sc-dots i:nth-child(3) { background: #28c840; }

  .sc-path {
    flex: 1;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    margin-right: 30px;
  }

  .sc-body { padding: 40px 36px 36px; text-align: center; }

  .sc-check {
    color: var(--color-success);
    margin-bottom: 20px;
    animation: check-pop 0.5s ease-out 0.3s both;
  }

  @keyframes check-pop {
    from { opacity: 0; transform: scale(0.5); }
    to { opacity: 1; transform: scale(1); }
  }

  .sc-body h1 {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.8rem;
    letter-spacing: -0.03em;
    margin-bottom: 10px;
  }

  .caret { color: var(--color-success); animation: blink 1s step-end infinite; }
  @keyframes blink { 50% { opacity: 0; } }

  .sc-sub {
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 28px;
  }

  .sc-steps {
    text-align: left;
    margin-bottom: 24px;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-success);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }

  .steps-list {
    list-style: none;
    padding: 0;
  }

  .steps-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    font-size: 0.88rem;
    color: var(--text-secondary);
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }

  .steps-list li:last-child { border-bottom: none; }

  .step-num {
    width: 24px;
    height: 24px;
    border-radius: 6px;
    background: rgba(34,197,94,0.1);
    color: var(--color-success);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sc-community {
    padding: 16px 20px;
    background: rgba(77,159,255,0.04);
    border: 1px solid rgba(77,159,255,0.08);
    border-radius: 10px;
    margin-bottom: 24px;
  }

  .sc-community p {
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .sc-community a { color: var(--accent); font-weight: 500; }

  .sc-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
  }

  @media (max-width: 520px) {
    .sc-body { padding: 32px 24px 28px; }
    .sc-body h1 { font-size: 1.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .success-card, .sc-check { animation: none; }
    .caret { animation: none; }
  }
</style>
