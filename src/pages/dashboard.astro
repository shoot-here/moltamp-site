---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Dashboard — MOLTamp Community">
  <Nav />
  <main class="dash-page">
    <div class="container">
      <!-- Header -->
      <div class="dash-header">
        <div class="dash-identity">
          <div class="dash-avatar" id="dash-avatar"></div>
          <div>
            <h1>Dashboard</h1>
            <p class="dash-user" id="dash-user"></p>
          </div>
        </div>
        <div class="dash-actions">
          <a href="/skins" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            Skins
          </a>
          <a href="/widgets" class="btn btn-secondary btn-sm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
            Widgets
          </a>
          <button class="btn btn-secondary btn-sm" id="logout-btn">Sign Out</button>
        </div>
      </div>

      <!-- Upload Section -->
      <section class="dash-section">
        <div class="section-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          <span>Upload a Skin</span>
        </div>
        <form id="upload-form" class="upload-form">
          <div class="upload-drop" id="upload-drop">
            <div class="drop-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
            </div>
            <p class="drop-text">Drop a <code>.zip</code> skin archive here</p>
            <p class="drop-hint">or click to browse</p>
            <input type="file" id="file-input" accept=".zip" />
          </div>

          <div class="upload-fields" id="upload-fields" style="display:none">
            <div class="upload-file-info">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
              <span id="upload-filename" class="mono"></span>
            </div>

            <div class="field">
              <label for="upload-tags">tags <span class="opt">// comma-separated, max 5</span></label>
              <input type="text" id="upload-tags" placeholder="retro, cyberpunk, minimal" maxlength="120" />
            </div>

            <p class="form-error" id="upload-error" role="alert"></p>

            <button type="submit" class="btn btn-primary upload-btn" id="upload-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              Upload Skin
            </button>
          </div>
        </form>
      </section>

      <!-- My Skins -->
      <section class="dash-section">
        <div class="section-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          <span>My Skins</span>
        </div>
        <div id="my-skins" class="my-skins-grid"></div>
        <div id="no-skins" class="empty-msg" style="display:none">
          <p>You haven't uploaded any skins yet.</p>
          <p class="empty-hint">Package a skin folder as a <code>.zip</code> and upload above.</p>
        </div>
      </section>

      <!-- Widget Upload Section -->
      <section class="dash-section">
        <div class="section-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          <span>Upload a Widget</span>
        </div>
        <form id="widget-upload-form" class="upload-form">
          <div class="upload-drop" id="widget-upload-drop">
            <div class="drop-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/>
              </svg>
            </div>
            <p class="drop-text">Drop a <code>.zip</code> widget archive here</p>
            <p class="drop-hint">Must contain <code>widget.json</code> + <code>index.html</code></p>
            <input type="file" id="widget-file-input" accept=".zip" />
          </div>

          <div class="upload-fields" id="widget-upload-fields" style="display:none">
            <div class="upload-file-info">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
              <span id="widget-upload-filename" class="mono"></span>
            </div>

            <div class="field">
              <label for="widget-upload-tags">tags <span class="opt">// comma-separated, max 5</span></label>
              <input type="text" id="widget-upload-tags" placeholder="telemetry, git, status" maxlength="120" />
            </div>

            <p class="form-error" id="widget-upload-error" role="alert"></p>

            <button type="submit" class="btn btn-primary upload-btn" id="widget-upload-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              Upload Widget
            </button>
          </div>
        </form>
      </section>

      <!-- My Widgets -->
      <section class="dash-section">
        <div class="section-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          <span>My Widgets</span>
        </div>
        <div id="my-widgets" class="my-widgets-grid"></div>
        <div id="no-widgets" class="empty-msg" style="display:none">
          <p>You haven't uploaded any widgets yet.</p>
          <p class="empty-hint">Package a widget folder (with <code>widget.json</code> + <code>index.html</code>) as a <code>.zip</code> and upload above.</p>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  let currentUser: { id: number; email: string; display_name: string } | null = null;

  async function checkAuth() {
    const res = await fetch('/api/auth/me');
    if (!res.ok) { window.location.href = '/login'; return; }
    const data = await res.json();
    currentUser = data.user;
    document.getElementById('dash-user')!.textContent = `${data.user.display_name} \u00B7 ${data.user.email}`;
    const avatar = document.getElementById('dash-avatar')!;
    avatar.textContent = data.user.display_name[0].toUpperCase();
  }

  checkAuth().then(() => { loadMySkins(); loadMyWidgets(); });

  // Logout
  document.getElementById('logout-btn')!.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/';
  });

  // File upload
  const dropZone = document.getElementById('upload-drop')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadFields = document.getElementById('upload-fields')!;
  const uploadFilename = document.getElementById('upload-filename')!;
  const uploadForm = document.getElementById('upload-form') as HTMLFormElement;
  const uploadBtn = document.getElementById('upload-btn') as HTMLButtonElement;
  const uploadError = document.getElementById('upload-error')!;
  let selectedFile: File | null = null;

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', (e) => { e.preventDefault(); dropZone.classList.remove('drag-over'); if (e.dataTransfer?.files[0]) selectFile(e.dataTransfer.files[0]); });
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) selectFile(fileInput.files[0]); });

  function selectFile(file: File) {
    selectedFile = file;
    uploadFilename.textContent = `${file.name} (${(file.size / 1024).toFixed(0)} KB)`;
    uploadFields.style.display = 'block';
    uploadError.textContent = '';
  }

  uploadForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!selectedFile) return;
    uploadError.textContent = '';
    uploadBtn.disabled = true;
    uploadBtn.querySelector('svg')!.style.display = 'none';
    uploadBtn.childNodes[uploadBtn.childNodes.length - 1].textContent = ' Uploading...';

    const formData = new FormData();
    formData.append('file', selectedFile);
    const tags = (document.getElementById('upload-tags') as HTMLInputElement).value;
    if (tags) formData.append('tags', tags);

    try {
      const res = await fetch('/api/skins', { method: 'POST', body: formData });
      let data: any;
      try { data = await res.json(); } catch { throw new Error(`Server returned ${res.status}`); }

      if (data.success) {
        selectedFile = null;
        fileInput.value = '';
        uploadFields.style.display = 'none';
        resetUploadBtn();
        if (data.skin?.warnings?.length) {
          uploadError.style.color = '#f59e0b';
          uploadError.textContent = 'Uploaded with warnings: ' + data.skin.warnings.join('; ');
        }
        loadMySkins();
      } else {
        const msg = data.errors?.join('; ') || data.error || 'Upload failed';
        uploadError.style.color = '#ef4444';
        uploadError.textContent = msg;
        resetUploadBtn();
      }
    } catch (err) {
      uploadError.style.color = '#ef4444';
      uploadError.textContent = err instanceof Error ? err.message : 'Something went wrong.';
      resetUploadBtn();
    }
  });

  function resetUploadBtn() {
    uploadBtn.disabled = false;
    uploadBtn.querySelector('svg')!.style.display = '';
    uploadBtn.childNodes[uploadBtn.childNodes.length - 1].textContent = ' Upload Skin';
  }

  // My skins
  async function loadMySkins() {
    const res = await fetch('/api/skins/mine');
    if (!res.ok) return;
    const data = await res.json();
    const container = document.getElementById('my-skins')!;
    const noSkins = document.getElementById('no-skins')!;

    if (data.skins.length === 0) { container.innerHTML = ''; noSkins.style.display = 'flex'; return; }
    noSkins.style.display = 'none';

    container.innerHTML = data.skins.map((skin: any) => {
      const c = skin.colors;
      const tags = skin.tags?.length ? skin.tags.join(', ') : '';
      return `
      <div style="display:flex;border:1px solid ${c.chromeBorder};border-radius:8px;overflow:hidden;margin-bottom:8px">
        <a href="/skins/view?id=${skin.skin_id}" style="width:80px;height:80px;flex-shrink:0;display:block;overflow:hidden;background:${c.chromeBg}">
          <div style="width:80px;height:80px;display:flex;flex-direction:column;font-family:var(--font-mono);font-size:0.4rem">
            <div style="display:flex;align-items:center;gap:3px;padding:4px 6px;border-bottom:1px solid ${c.chromeBorder}"><span style="width:5px;height:5px;border-radius:50%;background:#ff5f57;display:block"></span><span style="width:5px;height:5px;border-radius:50%;background:#febc2e;display:block"></span><span style="width:5px;height:5px;border-radius:50%;background:#28c840;display:block"></span></div>
            <div style="flex:1;background:${c.background};padding:4px 6px;display:flex;flex-direction:column;justify-content:flex-end"><span style="color:${c.green}">$ <span style="color:${c.foreground}">_</span></span></div>
            <div style="padding:2px 6px;border-top:1px solid ${c.chromeBorder};display:flex;align-items:center;gap:3px"><span style="width:4px;height:4px;border-radius:50%;background:${c.accent};display:block"></span><span style="color:${c.chromeDim};font-size:0.3rem">${skin.skin_id}</span></div>
          </div>
        </a>
        <div style="flex:1;padding:10px 14px;min-width:0">
          <div style="display:flex;align-items:baseline;justify-content:space-between;gap:12px;margin-bottom:4px">
            <a href="/skins/view?id=${skin.skin_id}" style="font-family:var(--font-heading);font-weight:700;font-size:0.92rem;color:${c.accent};text-decoration:none">${skin.name}</a>
            <span style="font-family:var(--font-mono);font-size:0.65rem;color:var(--text-dim);white-space:nowrap">v${skin.version} · ${skin.download_count} dl · ${(skin.file_size / 1024).toFixed(0)} KB · <span class="status-${skin.status}">${skin.status}</span></span>
          </div>
          <p style="font-size:0.8rem;color:var(--text-secondary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:2px" id="desc-display-${skin.skin_id}">${skin.description}</p>
          ${tags ? `<p style="font-family:var(--font-mono);font-size:0.68rem;color:var(--text-dim);margin-bottom:2px">${tags}</p>` : ''}
          <!-- Edit form (hidden) -->
          <div id="edit-form-${skin.skin_id}" style="display:none;margin:6px 0">
            <textarea id="edit-desc-${skin.skin_id}" rows="2" maxlength="500" style="width:100%;padding:6px 8px;background:rgba(0,0,0,0.3);border:1px solid var(--border);border-radius:4px;color:var(--text-primary);font-size:0.8rem;resize:vertical;outline:none;margin-bottom:4px">${skin.description}</textarea>
            <input type="text" id="edit-tags-${skin.skin_id}" value="${tags}" placeholder="tag1, tag2, tag3" maxlength="120" style="width:100%;max-width:280px;padding:5px 8px;background:rgba(0,0,0,0.3);border:1px solid var(--border);border-radius:4px;color:var(--text-primary);font-family:var(--font-mono);font-size:0.72rem;outline:none;margin-bottom:6px" />
            <div style="display:flex;gap:6px;align-items:center">
              <button class="btn btn-primary btn-xs save-edit-btn" data-skin-id="${skin.skin_id}">Save</button>
              <button class="btn btn-secondary btn-xs cancel-edit-btn" data-skin-id="${skin.skin_id}">Cancel</button>
              <span style="font-family:var(--font-mono);font-size:0.7rem" id="edit-status-${skin.skin_id}"></span>
            </div>
          </div>
          <div style="display:flex;gap:6px;margin-top:6px">
            <a href="/skins/view?id=${skin.skin_id}" class="btn btn-secondary btn-xs">View</a>
            <button class="btn btn-secondary btn-xs edit-btn" data-skin-id="${skin.skin_id}">Edit</button>
            <label class="btn btn-secondary btn-xs">
              Screenshots
              <input type="file" accept="image/png,image/jpeg,image/webp" multiple data-skin-id="${skin.skin_id}" class="ss-file-input" style="display:none" />
            </label>
            <button class="btn btn-secondary btn-xs delete-btn" data-skin-id="${skin.skin_id}" style="color:#ef4444;border-color:rgba(239,68,68,0.2)">Delete</button>
          </div>
          <p style="font-family:var(--font-mono);font-size:0.7rem;margin-top:4px;min-height:0" id="ss-status-${skin.skin_id}"></p>
        </div>
      </div>`;
    }).join('');

    // Delete handlers
    container.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const skinId = (btn as HTMLElement).dataset.skinId;
        if (!confirm(`Delete "${skinId}"?`)) return;
        const res = await fetch(`/api/skins/${skinId}`, { method: 'DELETE' });
        if (res.ok) loadMySkins();
      });
    });

    // Edit handlers
    container.querySelectorAll('.edit-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const skinId = (btn as HTMLElement).dataset.skinId!;
        const form = document.getElementById(`edit-form-${skinId}`)!;
        const desc = document.getElementById(`desc-display-${skinId}`)!;
        const tags = desc.nextElementSibling as HTMLElement;
        form.style.display = form.style.display === 'none' ? 'block' : 'none';
        desc.style.display = form.style.display === 'none' ? '' : 'none';
        if (tags?.classList.contains('sk-tags')) tags.style.display = desc.style.display;
      });
    });

    container.querySelectorAll('.cancel-edit-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const skinId = (btn as HTMLElement).dataset.skinId!;
        document.getElementById(`edit-form-${skinId}`)!.style.display = 'none';
        document.getElementById(`desc-display-${skinId}`)!.style.display = '';
        const tags = document.getElementById(`desc-display-${skinId}`)!.nextElementSibling as HTMLElement;
        if (tags?.classList.contains('sk-tags')) tags.style.display = '';
      });
    });

    container.querySelectorAll('.save-edit-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const skinId = (btn as HTMLElement).dataset.skinId!;
        const statusEl = document.getElementById(`edit-status-${skinId}`)!;
        const desc = (document.getElementById(`edit-desc-${skinId}`) as HTMLTextAreaElement).value;
        const tags = (document.getElementById(`edit-tags-${skinId}`) as HTMLInputElement).value;
        statusEl.textContent = 'Saving...';
        statusEl.style.color = 'var(--text-dim)';
        try {
          const res = await fetch(`/api/skins/${skinId}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ description: desc, tags }),
          });
          const data = await res.json();
          if (data.success) { loadMySkins(); }
          else { statusEl.textContent = data.error || 'Failed'; statusEl.style.color = '#ef4444'; }
        } catch { statusEl.textContent = 'Error'; statusEl.style.color = '#ef4444'; }
      });
    });

    // Screenshot upload handlers
    container.querySelectorAll('.ss-file-input').forEach(input => {
      input.addEventListener('change', async () => {
        const fi = input as HTMLInputElement;
        const skinId = fi.dataset.skinId!;
        const statusEl = document.getElementById(`ss-status-${skinId}`);
        const files = fi.files;
        if (!files || files.length === 0) return;
        if (files.length > 3) {
          if (statusEl) { statusEl.style.color = '#ef4444'; statusEl.textContent = 'Max 3 screenshots'; }
          return;
        }
        if (statusEl) { statusEl.style.color = 'var(--text-dim)'; statusEl.textContent = 'Uploading...'; }
        const formData = new FormData();
        for (let i = 0; i < files.length; i++) formData.append('file', files[i]);
        try {
          const res = await fetch(`/api/skins/${skinId}/screenshots`, { method: 'POST', body: formData });
          const data = await res.json();
          if (data.success) {
            if (statusEl) { statusEl.style.color = 'var(--color-success)'; statusEl.textContent = `${data.count} screenshot${data.count !== 1 ? 's' : ''} uploaded`; }
          } else {
            if (statusEl) { statusEl.style.color = '#ef4444'; statusEl.textContent = data.error || 'Upload failed'; }
          }
        } catch {
          if (statusEl) { statusEl.style.color = '#ef4444'; statusEl.textContent = 'Upload failed'; }
        }
        fi.value = '';
      });
    });
  }

  // ── Widget Upload ──
  const widgetDropZone = document.getElementById('widget-upload-drop')!;
  const widgetFileInput = document.getElementById('widget-file-input') as HTMLInputElement;
  const widgetUploadFields = document.getElementById('widget-upload-fields')!;
  const widgetUploadFilename = document.getElementById('widget-upload-filename')!;
  const widgetUploadForm = document.getElementById('widget-upload-form') as HTMLFormElement;
  const widgetUploadBtn = document.getElementById('widget-upload-btn') as HTMLButtonElement;
  const widgetUploadError = document.getElementById('widget-upload-error')!;
  let selectedWidgetFile: File | null = null;

  widgetDropZone.addEventListener('click', () => widgetFileInput.click());
  widgetDropZone.addEventListener('dragover', (e) => { e.preventDefault(); widgetDropZone.classList.add('drag-over'); });
  widgetDropZone.addEventListener('dragleave', () => widgetDropZone.classList.remove('drag-over'));
  widgetDropZone.addEventListener('drop', (e) => { e.preventDefault(); widgetDropZone.classList.remove('drag-over'); if (e.dataTransfer?.files[0]) selectWidgetFile(e.dataTransfer.files[0]); });
  widgetFileInput.addEventListener('change', () => { if (widgetFileInput.files?.[0]) selectWidgetFile(widgetFileInput.files[0]); });

  function selectWidgetFile(file: File) {
    selectedWidgetFile = file;
    widgetUploadFilename.textContent = `${file.name} (${(file.size / 1024).toFixed(0)} KB)`;
    widgetUploadFields.style.display = 'block';
    widgetUploadError.textContent = '';
  }

  widgetUploadForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!selectedWidgetFile) return;
    widgetUploadError.textContent = '';
    widgetUploadBtn.disabled = true;
    widgetUploadBtn.querySelector('svg')!.style.display = 'none';
    widgetUploadBtn.childNodes[widgetUploadBtn.childNodes.length - 1].textContent = ' Uploading...';

    const formData = new FormData();
    formData.append('file', selectedWidgetFile);
    const tags = (document.getElementById('widget-upload-tags') as HTMLInputElement).value;
    if (tags) formData.append('tags', tags);

    try {
      const res = await fetch('/api/widgets', { method: 'POST', body: formData });
      let data: any;
      try { data = await res.json(); } catch { throw new Error(`Server returned ${res.status}`); }

      if (data.success) {
        selectedWidgetFile = null;
        widgetFileInput.value = '';
        widgetUploadFields.style.display = 'none';
        resetWidgetUploadBtn();
        loadMyWidgets();
      } else {
        const msg = data.errors?.join('; ') || data.error || 'Upload failed';
        widgetUploadError.style.color = '#ef4444';
        widgetUploadError.textContent = msg;
        resetWidgetUploadBtn();
      }
    } catch (err) {
      widgetUploadError.style.color = '#ef4444';
      widgetUploadError.textContent = err instanceof Error ? err.message : 'Something went wrong.';
      resetWidgetUploadBtn();
    }
  });

  function resetWidgetUploadBtn() {
    widgetUploadBtn.disabled = false;
    widgetUploadBtn.querySelector('svg')!.style.display = '';
    widgetUploadBtn.childNodes[widgetUploadBtn.childNodes.length - 1].textContent = ' Upload Widget';
  }

  // My widgets
  async function loadMyWidgets() {
    const res = await fetch('/api/widgets/mine');
    if (!res.ok) return;
    const data = await res.json();
    const container = document.getElementById('my-widgets')!;
    const noWidgets = document.getElementById('no-widgets')!;

    if (data.widgets.length === 0) { container.innerHTML = ''; noWidgets.style.display = 'flex'; return; }
    noWidgets.style.display = 'none';

    container.innerHTML = data.widgets.map((widget: any) => {
      return `
      <div class="my-widget-card">
        <div class="my-widget-row">
          <div class="my-widget-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          </div>
          <div class="my-widget-info">
            <h3>${widget.name}</h3>
            <p class="widget-desc">${widget.description || 'No description'}</p>
            <div class="my-widget-meta">
              <span>v${widget.version}</span>
              <span>\u00B7</span>
              <span>${widget.download_count} downloads</span>
              <span>\u00B7</span>
              <span>${(widget.file_size / 1024).toFixed(0)} KB</span>
              <span>\u00B7</span>
              <span class="status-${widget.status}">${widget.status}</span>
            </div>
            <div class="my-widget-actions">
              <a href="/widgets/view?id=${widget.widget_id}" class="btn btn-secondary btn-xs">View</a>
              <button class="btn btn-secondary btn-xs widget-delete-btn" data-widget-id="${widget.widget_id}" style="color:#ef4444;border-color:rgba(239,68,68,0.2)">Delete</button>
            </div>
          </div>
        </div>
      </div>`;
    }).join('');

    // Delete handlers
    container.querySelectorAll('.widget-delete-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const widgetId = (btn as HTMLElement).dataset.widgetId;
        if (!confirm(`Delete widget "${widgetId}"?`)) return;
        const res = await fetch(`/api/widgets/${widgetId}`, { method: 'DELETE' });
        if (res.ok) loadMyWidgets();
      });
    });
  }
</script>

