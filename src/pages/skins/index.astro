---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Community Skins — MOLTamp"
  description="Browse and download community-built skins for MOLTamp. Cyberpunk, retro CRT, minimal, neon — customize your AI terminal with themes from the community."
  keywords="moltamp skins, terminal skins, terminal themes, ai terminal customization, claude code themes, cyberpunk terminal, retro terminal, vibe coding"
>
  <Nav />
  <main id="main-content" class="gallery-page">
    <!-- Hero -->
    <div class="gallery-hero">
      <div class="gallery-hero-bg" aria-hidden="true">
        <div class="hero-glow"></div>
        <div class="hero-grain"></div>
      </div>
      <div class="container">
        <div class="gallery-header">
          <h1 class="gallery-title">Skins</h1>
          <p class="gallery-desc">Community-built themes for MOLTamp. Browse, download, and make it yours.</p>
        </div>

        <!-- Featured (always visible, graceful empty) -->
        <div class="featured-section" id="featured-section">
          <div class="section-label">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span>Featured</span>
          </div>
          <div class="featured-row" id="featured-row">
            <div class="skeleton-card"></div>
            <div class="skeleton-card"></div>
            <div class="skeleton-card"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Gallery body -->
    <div class="container gallery-body">
      <!-- Filters -->
      <div class="filter-bar">
        <div class="filter-top">
          <div class="search-field">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" id="search-input" placeholder="Search skins..." />
          </div>
          <select id="sort-select" class="sort-pill">
            <option value="newest">Newest</option>
            <option value="popular">Most Downloaded</option>
            <option value="top-rated">Top Rated</option>
            <option value="updated">Recently Updated</option>
          </select>
        </div>
        <div class="tag-scroll" id="tag-chips"></div>
      </div>

      <!-- Grid with skeleton loader -->
      <div class="skins-grid" id="skins-grid">
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
        <div class="skeleton-card"></div>
      </div>

      <div class="pagination" id="pagination"></div>

      <div class="empty-state" id="empty-state" style="display:none;">
        <div class="empty-visual" aria-hidden="true">
          <div class="empty-terminal">
            <div class="et-bar"><span></span><span></span><span></span></div>
            <div class="et-body">
              <div class="et-line"></div>
              <div class="et-line short"></div>
              <div class="et-cursor"></div>
            </div>
          </div>
        </div>
        <p class="empty-title">No skins found</p>
        <p class="empty-sub">Try a different search, or <a href="/dashboard">create one</a>.</p>
      </div>

      <!-- CTA -->
      <div class="gallery-cta" id="gallery-cta">
        <div class="cta-card">
          <h3>Join the community</h3>
          <p>Download skins, upload your own, rate and comment.</p>
          <div class="cta-actions">
            <a href="/buy" class="btn btn-primary" id="cta-btn">Get a License — $20</a>
          </div>
          <p class="cta-sub" id="cta-sub">Already have a key? <a href="/login">Sign in</a></p>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script is:inline src="/js/skin-card.js"></script>
<script>
  let currentPage = 1, currentTag = '', currentSort = 'newest';
  let searchTimeout: ReturnType<typeof setTimeout>;
  let initialLoad = true;

  const grid = document.getElementById('skins-grid')!;
  const pagination = document.getElementById('pagination')!;
  const emptyState = document.getElementById('empty-state')!;
  const tagChips = document.getElementById('tag-chips')!;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
  const ctaBtn = document.getElementById('cta-btn') as HTMLAnchorElement;
  const ctaSub = document.getElementById('cta-sub') as HTMLElement;

  // Auth check — swap CTA
  fetch('/api/auth/me').then(r => {
    if (r.ok) {
      ctaBtn.href = '/dashboard';
      ctaBtn.textContent = 'Go to Dashboard';
      if (ctaSub) ctaSub.style.display = 'none';
    }
  });

  // Load featured skins (top 3 by popularity)
  fetch('/api/skins?sort=popular&limit=3').then(r => r.json()).then(data => {
    const row = document.getElementById('featured-row')!;
    if (data.skins.length === 0) {
      row.innerHTML = `
        <div class="featured-empty">
          <p>Be the first to <a href="/dashboard">upload a skin</a>.</p>
        </div>`;
      return;
    }
    row.innerHTML = data.skins.map((s: any) => renderSkinCard(s)).join('');
  }).catch(() => {
    document.getElementById('featured-row')!.innerHTML = '';
  });

  // Load tags
  fetch('/api/skins/tags').then(r => r.json()).then(data => {
    tagChips.innerHTML = data.tags.map((t: {tag:string;count:number}) =>
      `<button class="tag-chip" data-tag="${t.tag}">${t.tag}<span>${t.count}</span></button>`
    ).join('');
    tagChips.querySelectorAll('.tag-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = (btn as HTMLElement).dataset.tag!;
        currentTag = currentTag === tag ? '' : tag;
        tagChips.querySelectorAll('.tag-chip').forEach(b => b.classList.remove('active'));
        if (currentTag) btn.classList.add('active');
        currentPage = 1;
        loadSkins();
      });
    });
  });

  // Search
  searchInput.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => { currentPage = 1; loadSkins(); }, 300);
  });

  // Sort
  sortSelect.addEventListener('change', () => {
    currentSort = sortSelect.value;
    currentPage = 1;
    loadSkins();
  });

  async function loadSkins() {
    // Show skeleton on subsequent loads (initial has server-rendered skeletons)
    if (!initialLoad) {
      grid.innerHTML = Array(8).fill('<div class="skeleton-card"></div>').join('');
    }

    const params = new URLSearchParams({ page: String(currentPage), sort: currentSort, limit: '24' });
    if (searchInput.value.trim()) params.set('q', searchInput.value.trim());
    if (currentTag) params.set('tag', currentTag);

    const data = await fetch(`/api/skins?${params}`).then(r => r.json());
    initialLoad = false;

    if (data.skins.length === 0) {
      grid.innerHTML = '';
      emptyState.style.display = 'flex';
      pagination.innerHTML = '';
      return;
    }

    emptyState.style.display = 'none';
    grid.innerHTML = data.skins.map((s: any) => renderSkinCard(s)).join('');
    renderPag(data.pagination);
  }

  function renderPag(p: {page:number;pages:number;total:number}) {
    if (p.pages <= 1) { pagination.innerHTML = ''; return; }
    let h = '';
    if (p.page > 1) h += `<button class="pg" data-p="${p.page-1}"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg></button>`;
    for (let i = 1; i <= p.pages; i++) {
      if (i === p.page) h += `<span class="pg-cur">${i}</span>`;
      else if (Math.abs(i - p.page) <= 2 || i === 1 || i === p.pages) h += `<button class="pg" data-p="${i}">${i}</button>`;
      else if (Math.abs(i - p.page) === 3) h += '<span class="pg-dot">&middot;&middot;&middot;</span>';
    }
    if (p.page < p.pages) h += `<button class="pg" data-p="${p.page+1}"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg></button>`;
    pagination.innerHTML = h;
    pagination.querySelectorAll('.pg').forEach(b => b.addEventListener('click', () => {
      currentPage = parseInt((b as HTMLElement).dataset.p!);
      loadSkins();
      window.scrollTo({ top: document.querySelector('.gallery-body')!.offsetTop - 80, behavior: 'smooth' });
    }));
  }

  loadSkins();
</script>

<style>
  /* ── Hero ── */
  .gallery-hero {
    position: relative;
    padding: calc(var(--nav-height) + 48px) 0 0;
    overflow: hidden;
  }

  .gallery-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(77, 159, 255, 0.07) 0%, transparent 70%);
  }

  .hero-grain {
    position: absolute;
    inset: 0;
    opacity: 0.02;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px;
  }

  .gallery-header {
    position: relative;
    margin-bottom: 40px;
  }

  .gallery-title {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(2.8rem, 7vw, 4rem);
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--text-primary) 40%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 12px;
  }

  .gallery-desc {
    color: var(--text-dim);
    font-size: 1rem;
    max-width: 400px;
    line-height: 1.6;
  }

  /* ── Featured ── */
  .featured-section {
    margin-bottom: 0;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 14px;
  }

  .featured-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .featured-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 20px;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.02);
    border: 1px dashed var(--border);
  }

  .featured-empty p {
    color: var(--text-dim);
    font-size: 0.9rem;
  }

  .featured-empty a {
    color: var(--accent);
    font-weight: 500;
  }

  /* ── Skeleton loader ── */
  .skeleton-card {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    background: linear-gradient(110deg, rgba(255,255,255,0.03) 8%, rgba(255,255,255,0.06) 18%, rgba(255,255,255,0.03) 33%);
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
    border: 1px solid var(--border);
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Gallery body ── */
  .gallery-body {
    padding-top: 32px;
    padding-bottom: 60px;
  }

  /* ── Filter bar ── */
  .filter-bar {
    margin-bottom: 28px;
  }

  .filter-top {
    display: flex;
    gap: 10px;
    margin-bottom: 12px;
  }

  .search-field {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text-dim);
    flex: 1;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .search-field:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(77, 159, 255, 0.08);
  }

  .search-field input {
    flex: 1;
    background: none;
    border: none;
    color: var(--text-primary);
    font-size: 0.9rem;
    outline: none;
  }

  .search-field input::placeholder { color: var(--text-dim); }

  .tag-scroll {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 5px 12px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .tag-chip:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(77, 159, 255, 0.05);
  }

  .tag-chip.active {
    background: rgba(77, 159, 255, 0.1);
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 12px rgba(77, 159, 255, 0.1);
  }

  .tag-chip span {
    color: var(--text-dim);
    font-size: 0.6rem;
    opacity: 0.5;
  }

  .sort-pill {
    padding: 10px 16px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text-secondary);
    font-size: 0.82rem;
    cursor: pointer;
    flex-shrink: 0;
    outline: none;
  }

  .sort-pill:focus {
    border-color: var(--accent);
  }

  /* ── Grid ── */
  .skins-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .skin-card {
    display: block;
    position: relative;
    border: 1px solid;
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .skin-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
    color: inherit;
  }

  .skin-card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 28px 12px 10px;
    pointer-events: none;
    transition: opacity 0.2s;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .skin-card-name { font-size: 0.82rem; font-weight: 600; }
  .skin-card-stars { display: flex; align-items: center; gap: 1px; }

  .skin-card-hover {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    opacity: 0;
    transition: opacity 0.2s;
    font-size: 0.8rem;
  }

  .skin-card:hover .skin-card-hover { opacity: 1; }
  .skin-card:hover .skin-card-overlay { opacity: 0; }

  .hover-author { font-weight: 500; font-size: 0.85rem; }
  .hover-stars { display: flex; align-items: center; gap: 1px; }
  .hover-downloads { font-size: 0.72rem; opacity: 0.7; }

  /* ── Pagination ── */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4px;
    margin-top: 32px;
  }

  .pg {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 8px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 0.82rem;
    font-family: var(--font-mono);
    transition: all 0.15s;
  }

  .pg:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(77, 159, 255, 0.05);
  }

  .pg-cur {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 8px;
    background: var(--accent);
    color: #fff;
    border-radius: 8px;
    font-size: 0.82rem;
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .pg-dot {
    color: var(--text-dim);
    padding: 0 4px;
    letter-spacing: 2px;
  }

  /* ── Empty state (intentional design) ── */
  .empty-state {
    flex-direction: column;
    align-items: center;
    padding: 72px 0;
    text-align: center;
  }

  .empty-visual {
    margin-bottom: 24px;
  }

  .empty-terminal {
    width: 120px;
    border-radius: 8px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    overflow: hidden;
    opacity: 0.4;
  }

  .et-bar {
    display: flex;
    gap: 4px;
    padding: 6px 8px;
    border-bottom: 1px solid var(--border);
  }

  .et-bar span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border-hover);
  }

  .et-body { padding: 10px 10px 14px; }

  .et-line {
    height: 4px;
    border-radius: 2px;
    background: var(--border);
    margin-bottom: 6px;
    width: 80%;
  }

  .et-line.short { width: 50%; }

  .et-cursor {
    width: 8px;
    height: 10px;
    border-radius: 1px;
    background: var(--accent);
    opacity: 0.4;
    animation: blink 1.2s step-end infinite;
  }

  @keyframes blink { 50% { opacity: 0; } }

  .empty-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 6px;
  }

  .empty-sub {
    font-size: 0.88rem;
    color: var(--text-dim);
  }

  .empty-sub a { color: var(--accent); }

  /* ── CTA ── */
  .gallery-cta {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  .cta-card {
    text-align: center;
    padding: 40px 24px;
    border-radius: var(--radius-lg);
    background: linear-gradient(145deg, rgba(77, 159, 255, 0.04) 0%, rgba(255, 107, 77, 0.03) 100%);
    border: 1px solid rgba(77, 159, 255, 0.08);
  }

  .cta-card h3 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.4rem;
    margin-bottom: 8px;
  }

  .cta-card p {
    color: var(--text-dim);
    font-size: 0.92rem;
    margin-bottom: 20px;
  }

  .cta-actions {
    display: flex;
    justify-content: center;
  }

  .cta-sub {
    font-size: 0.82rem;
    margin-top: 12px;
    color: var(--text-dim);
  }

  .cta-sub a { color: var(--accent); }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .skins-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .skins-grid { grid-template-columns: repeat(2, 1fr); }
    .featured-row { grid-template-columns: repeat(2, 1fr); }
    .featured-row .skin-card:nth-child(3) { display: none; }
    .filter-top { flex-direction: column; }

    .gallery-title {
      font-size: clamp(2rem, 10vw, 3rem);
    }
  }

  @media (max-width: 480px) {
    .skins-grid { grid-template-columns: 1fr; }
    .featured-row { grid-template-columns: 1fr; }
    .featured-row .skin-card:nth-child(2),
    .featured-row .skin-card:nth-child(3) { display: none; }
  }
</style>
