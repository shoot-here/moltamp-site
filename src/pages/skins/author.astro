---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Author — MOLTamp Community">
  <Nav />
  <main class="author-page">
    <div class="container">
      <a href="/skins" class="back">← Gallery</a>
      <div id="author-detail"><div class="loading">Loading author...</div></div>
      <div class="skins-grid" id="author-skins"></div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script is:inline src="/js/skin-card.js"></script>
<script>
  const authorName = new URLSearchParams(window.location.search).get('name') || '';
  const detail = document.getElementById('author-detail')!;
  const grid = document.getElementById('author-skins')!;

  if (!authorName) detail.innerHTML = '<p class="not-found">No author specified. <a href="/skins">Browse gallery</a></p>';

  async function load() {
    if (!authorName) return;
    const res = await fetch(`/api/authors/${encodeURIComponent(authorName)}`);
    if (!res.ok) { detail.innerHTML = '<p class="not-found">Author not found. <a href="/skins">Browse gallery</a></p>'; return; }
    const { author } = await res.json();
    document.title = `${author.display_name} — MOLTamp Community`;

    detail.innerHTML = `<div class="aheader">
      <div class="aavatar" style="background:var(--accent)">${author.display_name[0].toUpperCase()}</div>
      <div><h1>${author.display_name}</h1>
      <div class="astats"><span>Joined ${new Date(author.joined).toLocaleDateString()}</span><span>${author.skin_count} skin${author.skin_count!==1?'s':''}</span><span>${author.total_downloads} downloads</span></div>
      </div></div>`;

    const skinsRes = await fetch(`/api/skins?author=${encodeURIComponent(authorName)}&limit=48`);
    const data = await skinsRes.json();
    grid.innerHTML = data.skins.map((s: any) => renderSkinCard(s)).join('');
  }
  load();
</script>

<style>
  .author-page { padding:calc(var(--nav-height)+24px) 0 80px; }
  .back { display:inline-block; color:var(--text-secondary); font-size:0.85rem; margin-bottom:20px; }
  .back:hover { color:var(--accent); }
  .loading,.not-found { text-align:center; padding:80px 0; color:var(--text-dim); }

  .aheader { display:flex; align-items:center; gap:20px; margin-bottom:32px; }
  .aavatar { width:56px; height:56px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.4rem; font-weight:700; color:#fff; flex-shrink:0; }
  .aheader h1 { font-size:1.6rem; margin-bottom:4px; }
  .astats { display:flex; gap:16px; font-size:0.82rem; color:var(--text-dim); }

  .skins-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; }

  /* Card + MiniTerminal styles from /css/mini-terminal.css (.mt-sm via skin-card.js) */
  .skin-card { display:block; position:relative; border:1px solid; border-radius:var(--radius-md); overflow:hidden; text-decoration:none; transition:transform var(--transition-fast); }
  .skin-card:hover { transform:translateY(-3px); box-shadow:0 8px 24px rgba(0,0,0,0.4); color:inherit; }
  .skin-card-overlay { position:absolute; bottom:0; left:0; right:0; padding:20px 10px 6px; pointer-events:none; }
  .skin-card-name { font-size:0.78rem; font-weight:600; }
  .skin-card-hover { position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:4px; opacity:0; transition:opacity var(--transition-fast); font-size:0.75rem; }
  .skin-card:hover .skin-card-hover { opacity:1; }
  .skin-card:hover .skin-card-overlay { opacity:0; }

  @media (max-width:1100px) { .skins-grid { grid-template-columns:repeat(3,1fr); } }
  @media (max-width:768px) { .skins-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:480px) { .skins-grid { grid-template-columns:1fr; } }
</style>
