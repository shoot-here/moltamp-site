---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="404 — MOLTamp">
  <Nav />
  <main class="error-page">
    <div class="container">
      <div class="error-content">
        <span class="error-code">404</span>
        <h1>Page not found</h1>
        <p>This page doesn't exist. Maybe it was a skin that didn't load.</p>
        <a href="/" class="btn btn-primary">Back to home</a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .error-page {
    padding: calc(var(--nav-height) + 80px) 0 120px;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .error-content {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .error-code {
    font-family: var(--font-mono);
    font-size: 6rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--border-hover);
    line-height: 1;
    display: block;
    margin-bottom: 16px;
  }

  h1 {
    font-size: 1.8rem;
    margin-bottom: 12px;
  }

  p {
    color: var(--text-secondary);
    margin-bottom: 32px;
  }
</style>
