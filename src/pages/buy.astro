---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Unlock MOLTamp — $20 Lifetime License">
  <Nav />
  <main class="buy-scene">
    <div class="scene-bg" aria-hidden="true">
      <div class="scene-glow"></div>
      <div class="scene-grain"></div>
    </div>

    <div class="buy-card">
      <div class="bc-bar">
        <div class="bc-dots"><i></i><i></i><i></i></div>
        <span class="bc-path">moltamp://unlock</span>
      </div>
      <div class="bc-body">
        <img src="/images/logo.png" alt="" class="bc-logo" width="48" height="48" />
        <h1>Unlock MOLTamp<span class="caret">_</span></h1>
        <p class="bc-sub">One payment. Lifetime license. The nag popup disappears forever.</p>

        <div class="bc-price">
          <span class="price">$20</span>
          <span class="price-unit">USD · one-time</span>
        </div>

        <div class="bc-includes">
          <div class="section-label">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span>What you get</span>
          </div>
          <ul class="includes-list">
            <li>License key emailed instantly</li>
            <li>No nag popup — ever again</li>
            <li>Upload &amp; download community skins</li>
            <li>Works offline after first activation</li>
            <li>30-day refund guarantee</li>
          </ul>
        </div>

        <form id="checkout-form" class="bc-form">
          <div class="field">
            <label for="email">email</label>
            <div class="input-wrap">
              <span class="input-prefix">$</span>
              <input type="email" id="email" name="email" placeholder="you@example.com" required autocomplete="email" />
            </div>
          </div>

          <p class="form-error" id="form-error" role="alert"></p>

          <button type="submit" class="bc-submit" id="checkout-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span>Pay $20 — Get License Key</span>
          </button>

          <p class="bc-secure">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Secure checkout via Stripe. We never see your card.
          </p>
        </form>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('checkout-form') as HTMLFormElement;
  const btn = document.getElementById('checkout-btn') as HTMLButtonElement;
  const errorEl = document.getElementById('form-error') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('email') as HTMLInputElement).value;

    errorEl.textContent = '';
    btn.disabled = true;
    btn.querySelector('span')!.textContent = 'Redirecting to Stripe...';

    try {
      const res = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      const data = await res.json();

      if (data.url) {
        window.location.href = data.url;
      } else {
        throw new Error(data.error || 'Failed to create checkout session');
      }
    } catch {
      btn.disabled = false;
      btn.querySelector('span')!.textContent = 'Pay $20 — Get License Key';
      errorEl.textContent = 'Something went wrong. Please try again.';
    }
  });
</script>

<style>
  .buy-scene {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(var(--nav-height) + 40px) 24px 60px;
    position: relative;
    overflow: hidden;
  }

  .scene-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
  }

  .scene-glow {
    position: absolute;
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(77, 159, 255, 0.08) 0%, transparent 70%);
  }

  .scene-grain {
    position: absolute;
    inset: 0;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px;
  }

  .buy-card {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 480px;
    border-radius: 16px;
    overflow: hidden;
    background: rgba(14, 14, 18, 0.85);
    backdrop-filter: blur(24px) saturate(1.2);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: 0 0 0 1px rgba(0,0,0,0.3), 0 20px 60px rgba(0,0,0,0.5), 0 0 80px rgba(77,159,255,0.03);
    animation: card-in 0.8s ease-out both;
  }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(24px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .bc-bar {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    background: rgba(255,255,255,0.02);
  }

  .bc-dots { display: flex; gap: 6px; }
  .bc-dots i { width: 10px; height: 10px; border-radius: 50%; display: block; }
  .bc-dots i:nth-child(1) { background: #ff5f57; }
  .bc-dots i:nth-child(2) { background: #febc2e; }
  .bc-dots i:nth-child(3) { background: #28c840; }

  .bc-path {
    flex: 1;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    margin-right: 30px;
  }

  .bc-body { padding: 40px 36px 36px; }

  .bc-logo {
    display: block;
    width: 48px;
    height: 48px;
    object-fit: contain;
    margin-bottom: 16px;
    filter: drop-shadow(0 0 12px rgba(255, 80, 40, 0.3));
  }

  .bc-body h1 {
    font-weight: 700;
    font-size: 1.8rem;
    letter-spacing: -0.03em;
    margin-bottom: 10px;
  }

  .caret { color: var(--accent); animation: blink 1s step-end infinite; }
  @keyframes blink { 50% { opacity: 0; } }

  .bc-sub {
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 28px;
  }

  .bc-price {
    text-align: center;
    margin-bottom: 28px;
    padding: 24px;
    background: rgba(77,159,255,0.04);
    border: 1px solid rgba(77,159,255,0.08);
    border-radius: 12px;
  }

  .price {
    font-weight: 700;
    font-size: 3rem;
    letter-spacing: -0.04em;
    display: block;
  }

  .price-unit {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
    margin-top: 4px;
    display: block;
  }

  .bc-includes { margin-bottom: 28px; }

  .section-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }

  .includes-list {
    list-style: none;
    padding: 0;
  }

  .includes-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 0;
    font-size: 0.88rem;
    color: var(--text-secondary);
  }

  .includes-list li::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.6;
    flex-shrink: 0;
  }

  /* Form */
  .field { margin-bottom: 16px; }

  .field label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 6px;
    letter-spacing: 0.03em;
  }

  .input-wrap {
    display: flex;
    align-items: center;
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .input-wrap:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(77,159,255,0.1);
  }

  .input-prefix {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    padding: 0 0 0 14px;
    opacity: 0.5;
    user-select: none;
  }

  .input-wrap input {
    flex: 1;
    padding: 13px 14px 13px 8px;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.88rem;
    outline: none;
  }

  .input-wrap input::placeholder { color: rgba(255,255,255,0.15); }

  .form-error {
    color: #ef4444;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    min-height: 1.2em;
    margin-bottom: 4px;
  }

  .bc-submit {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 24px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 0 24px rgba(77,159,255,0.2);
  }

  .bc-submit:hover:not(:disabled) {
    background: var(--accent-hover);
    box-shadow: 0 0 36px rgba(77,159,255,0.3);
    transform: translateY(-1px);
  }

  .bc-submit:disabled { opacity: 0.6; cursor: wait; }

  .bc-secure {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 16px;
    font-size: 0.72rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
  }

  @media (max-width: 520px) {
    .bc-body { padding: 32px 24px 28px; }
    .bc-body h1 { font-size: 1.5rem; }
    .price { font-size: 2.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .buy-card { animation: none; }
    .caret { animation: none; }
  }
</style>
