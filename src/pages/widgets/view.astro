---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Widget — MOLTamp Community">
  <Nav />
  <main class="detail-page">
    <!-- Atmospheric background -->
    <div class="detail-bg" aria-hidden="true">
      <div class="detail-glow"></div>
      <div class="detail-glow detail-glow--warm"></div>
      <div class="detail-grain"></div>
    </div>
    <div class="container">
      <div id="widget-detail"><div class="detail-loading">Loading widget...</div></div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const widgetId = new URLSearchParams(window.location.search).get('id');
  const container = document.getElementById('widget-detail')!;
  let currentUser: any = null;

  if (!widgetId) { container.innerHTML = '<p class="not-found">No widget specified. <a href="/widgets">Browse gallery</a></p>'; }

  // Wait for auth check before rendering so download button is correct
  const authReady = fetch('/api/auth/me').then(r => r.ok ? r.json() : null).then(d => { if (d) currentUser = d.user; });

  function starSvg(filled: boolean) {
    return `<svg width="18" height="18" viewBox="0 0 24 24" fill="${filled ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;
  }

  function renderStars(avg: number, count: number, userRating: number | null, interactive: boolean) {
    const rounded = Math.round(avg);
    let stars = '';
    for (let i = 1; i <= 5; i++) {
      const filled = i <= rounded;
      const userFilled = userRating ? i <= userRating : false;
      const cls = interactive ? `star-btn${userFilled ? ' rated' : ''}` : 'star-static';
      const colorCls = (interactive ? userFilled : filled) ? 'star-filled' : 'star-empty';
      stars += `<span class="${cls} ${colorCls}" data-v="${i}">${starSvg(interactive ? userFilled : filled)}</span>`;
    }
    const label = count > 0
      ? `<span class="star-label">${avg} (${count})</span>`
      : `<span class="star-label">No ratings yet</span>`;
    return `<div class="d-stars" id="d-stars">${stars}${label}</div>`;
  }

  async function submitRating(value: number) {
    const res = await fetch(`/api/widgets/${widgetId}/ratings`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ rating: value }),
    });
    const data = await res.json();
    if (data.success) {
      const starsEl = document.getElementById('d-stars');
      if (starsEl) starsEl.outerHTML = renderStars(data.avg_rating, data.rating_count, data.user_rating, true);
      bindStarClicks();
    }
  }

  function bindStarClicks() {
    document.querySelectorAll('.star-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const v = parseInt((btn as HTMLElement).dataset.v!);
        submitRating(v);
      });
    });
  }

  async function load() {
    if (!widgetId) return;
    await authReady;
    const res = await fetch(`/api/widgets/${widgetId}`);
    if (!res.ok) { container.innerHTML = '<p class="not-found">Widget not found. <a href="/widgets">Browse gallery</a></p>'; return; }
    const { widget } = await res.json();
    document.title = `${widget.name} — MOLTamp Community`;

    const tags = widget.tags?.length ? widget.tags.map((t:string) => `<a href="/widgets?tag=${t}" class="widget-tag">${t}</a>`).join('') : '';
    const size = (widget.file_size / 1024).toFixed(0);

    // Ratings — fetch separately for user-specific data
    let ratingsHtml = renderStars(widget.avg_rating || 0, widget.rating_count || 0, null, false);

    container.innerHTML = `
      <a href="/widgets" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Gallery
      </a>

      <div class="detail-layout">
        <!-- LEFT COLUMN: widget preview -->
        <div class="detail-left">
          <div class="widget-preview-card">
            <div class="wp-live-preview">
              <iframe
                src="/api/widgets/${widget.widget_id}/preview"
                sandbox="allow-scripts"
                loading="lazy"
                title="${widget.name} live preview"
                class="wp-preview-iframe">
              </iframe>
            </div>
            <div class="wp-info">
              <h2 class="wp-name">${widget.name}</h2>
              <p class="wp-author">by ${widget.author_name}</p>
              <div class="wp-stats">
                <span>${widget.download_count} download${widget.download_count !== 1 ? 's' : ''}</span>
                <span class="wp-sep">/</span>
                <span>${size} KB</span>
                <span class="wp-sep">/</span>
                <span>v${widget.version}</span>
              </div>
            </div>
          </div>

          <div class="detail-card install-card">
            <div class="section-label">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              <span>INSTALL</span>
            </div>
            <ol class="install-steps">
              <li>Download the <code>.zip</code> file</li>
              <li>Open MOLTamp → Settings → Widgets</li>
              <li>Click <strong>Import</strong> and select the file</li>
            </ol>
          </div>
        </div>

        <!-- RIGHT COLUMN: metadata + download -->
        <div class="detail-right">
          <div class="detail-header">
            <h1 class="widget-name">${widget.name}</h1>
            <div class="widget-meta">
              <span class="author-text">${widget.author_name}</span>
              <span class="meta-sep">/</span>
              <span>v${widget.version}</span>
              <span class="meta-sep">/</span>
              <span>${widget.download_count} download${widget.download_count!==1?'s':''}</span>
              <span class="meta-sep">/</span>
              <span>${size} KB</span>
            </div>
          </div>

          <div class="ratings-area" id="ratings-area">${ratingsHtml}</div>

          ${currentUser
            ? `<a href="/api/widgets/${widgetId}/download" class="download-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                <span>Download Widget</span>
              </a>`
            : `<a href="/login" class="download-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                <span>Login to Download</span>
              </a>`
          }

          <p class="widget-description">${widget.description || 'No description provided.'}</p>

          ${tags ? `<div class="tags-row"><div class="tags-wrap">${tags}</div></div>` : ''}
        </div>
      </div>

      <div class="comments-section">
        <div class="section-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span>COMMENTS</span>
        </div>
        <div id="cform"></div>
        <div id="clist" class="comments-list">Loading comments...</div>
      </div>
    `;

    // Load ratings with user-specific data
    loadRatings();
    loadComments();
    bindStarClicks();
  }

  async function loadRatings() {
    try {
      const res = await fetch(`/api/widgets/${widgetId}/ratings`);
      const data = await res.json();
      const area = document.getElementById('ratings-area');
      if (area) {
        const interactive = currentUser !== null;
        area.innerHTML = renderStars(data.avg_rating, data.rating_count, data.user_rating, interactive);
        bindStarClicks();
      }
    } catch {}
  }

  async function loadComments() {
    const cform = document.getElementById('cform')!;
    const clist = document.getElementById('clist')!;

    if (currentUser) {
      cform.innerHTML = `
        <form id="cf" class="comment-form">
          <textarea id="ct" placeholder="Leave a comment..." maxlength="500" rows="3" class="comment-textarea"></textarea>
          <div class="comment-form-footer">
            <span class="comment-counter" id="cc">0/500</span>
            <button type="submit" class="comment-submit">Post</button>
          </div>
          <p class="comment-error" id="cerr"></p>
        </form>`;
      const ta = document.getElementById('ct') as HTMLTextAreaElement;
      ta.addEventListener('input', () => { document.getElementById('cc')!.textContent = `${ta.value.length}/500`; });
      document.getElementById('cf')!.addEventListener('submit', async (e) => {
        e.preventDefault();
        const comment = ta.value.trim();
        if (!comment) return;
        const r = await fetch(`/api/widgets/${widgetId}/comments`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({comment}) });
        const d = await r.json();
        if (d.success) { ta.value = ''; document.getElementById('cc')!.textContent = '0/500'; loadComments(); }
        else document.getElementById('cerr')!.textContent = d.error || 'Failed';
      });
    } else {
      cform.innerHTML = `<p class="comment-signin"><a href="/login">Sign in</a> to leave a comment.</p>`;
    }

    const res = await fetch(`/api/widgets/${widgetId}/comments?limit=50`);
    const data = await res.json();
    if (data.comments.length === 0) {
      clist.innerHTML = '<p class="comments-empty">No comments yet. Be the first!</p>';
    } else {
      clist.innerHTML = data.comments.map((c:any) => `
        <div class="comment-item">
          <div class="comment-header">
            <strong class="comment-author">${c.author}</strong>
            <span class="comment-date">${new Date(c.created_at).toLocaleDateString()}</span>
          </div>
          <p class="comment-body">${c.comment}</p>
        </div>`).join('');
    }
  }

  load();
</script>

<style>
  /* ── Page scene ── */
  .detail-page {
    position: relative;
    padding: calc(var(--nav-height) + 40px) 0 80px;
    min-height: 100vh;
  }

  .detail-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .detail-glow {
    position: absolute;
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(77, 159, 255, 0.06) 0%, transparent 70%);
  }

  .detail-glow--warm {
    top: auto;
    bottom: -200px;
    left: 30%;
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(255, 107, 77, 0.04) 0%, transparent 70%);
  }

  .detail-grain {
    position: absolute;
    inset: 0;
    opacity: 0.02;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
  }

  .container {
    position: relative;
    z-index: 1;
  }

  /* ── Loading + error ── */
  .detail-loading,
  .not-found {
    text-align: center;
    padding: 80px 0;
    color: var(--text-dim);
    font-size: 1rem;
  }

  .not-found a {
    color: var(--accent);
  }

  /* ── Back link ── */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    margin-bottom: 32px;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--accent);
  }

  /* ── Two-column layout ── */
  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-bottom: 48px;
  }

  .detail-left {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .detail-right {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ── Widget preview card ── */
  .widget-preview-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 40px 24px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-base);
  }

  .widget-preview-card:hover {
    border-color: var(--border-hover);
  }

  .wp-live-preview {
    width: 100%;
    height: 340px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: #0a0a0f;
    border: 1px solid var(--border);
    margin-bottom: 20px;
  }

  .wp-preview-iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .wp-info {
    text-align: center;
  }

  .wp-name {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .wp-author {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
    margin-bottom: 16px;
  }

  .wp-stats {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
  }

  .wp-sep {
    opacity: 0.3;
  }

  /* ── Shared card style ── */
  .detail-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 20px 24px;
    transition: border-color var(--transition-base);
  }

  .detail-card:hover {
    border-color: var(--border-hover);
  }

  /* ── Section labels ── */
  .section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 14px;
    font-weight: 500;
  }

  .section-label svg {
    opacity: 0.7;
  }

  /* ── Header / Meta ── */
  .detail-header {
    padding-bottom: 4px;
  }

  .widget-name {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
    color: var(--accent);
  }

  .widget-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  .meta-sep {
    opacity: 0.3;
  }

  .author-text {
    color: var(--accent);
    font-weight: 500;
  }

  /* ── Ratings ── */
  .ratings-area {
    padding: 4px 0;
  }

  .d-stars {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .star-btn,
  .star-static {
    display: inline-flex;
    vertical-align: middle;
    transition: transform var(--transition-fast);
  }

  .star-btn {
    cursor: pointer;
  }

  .star-btn:hover {
    transform: scale(1.2);
  }

  .star-static {
    cursor: default;
  }

  .star-filled {
    color: #fbbf24;
  }

  .star-empty {
    color: var(--text-dim);
  }

  .star-label {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    margin-left: 8px;
    vertical-align: middle;
  }

  /* ── Download button ── */
  .download-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 14px 24px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 0 24px rgba(77, 159, 255, 0.2);
    text-decoration: none;
  }

  .download-btn:hover {
    background: var(--accent-hover);
    color: #fff;
    box-shadow: 0 0 36px rgba(77, 159, 255, 0.3);
    transform: translateY(-1px);
  }

  /* ── Description ── */
  .widget-description {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* ── Tags ── */
  .tags-row {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .tags-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .widget-tag {
    display: inline-block;
    padding: 4px 12px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .widget-tag:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(77, 159, 255, 0.05);
  }

  /* ── Install card ── */
  .install-card {
    margin-top: auto;
  }

  .install-steps {
    padding-left: 20px;
    color: var(--text-secondary);
    font-size: 0.88rem;
    line-height: 1.7;
    list-style: none;
    counter-reset: step;
  }

  .install-steps li {
    counter-increment: step;
    padding: 6px 0;
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .install-steps li::before {
    content: counter(step);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(77, 159, 255, 0.1);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
  }

  .install-steps code {
    font-family: var(--font-mono);
    background: rgba(255, 255, 255, 0.06);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.85em;
    color: var(--accent);
  }

  .install-steps strong {
    color: var(--text-primary);
  }

  /* ── Comments section ── */
  .comments-section {
    border-top: 1px solid var(--border);
    padding-top: 36px;
    max-width: 720px;
  }

  .comments-list {
    color: var(--text-dim);
    font-size: 0.9rem;
  }

  .comments-empty {
    color: var(--text-dim);
    font-size: 0.9rem;
    padding: 24px 0;
  }

  /* Comment form */
  .comment-form {
    margin-bottom: 24px;
  }

  .comment-textarea {
    width: 100%;
    padding: 14px 16px;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: 0.9rem;
    font-family: var(--font-display);
    resize: vertical;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    line-height: 1.5;
  }

  .comment-textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(77, 159, 255, 0.08);
  }

  .comment-textarea::placeholder {
    color: var(--text-dim);
  }

  .comment-form-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 10px;
  }

  .comment-counter {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.02em;
  }

  .comment-submit {
    padding: 8px 20px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.02em;
  }

  .comment-submit:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }

  .comment-error {
    color: #ef4444;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    margin-top: 6px;
    min-height: 1em;
  }

  .comment-signin {
    color: var(--text-dim);
    font-size: 0.9rem;
    margin-bottom: 20px;
  }

  .comment-signin a {
    color: var(--accent);
    font-weight: 500;
  }

  /* Individual comment */
  .comment-item {
    padding: 18px 0;
    border-bottom: 1px solid var(--border);
  }

  .comment-item:last-child {
    border-bottom: none;
  }

  .comment-header {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 6px;
  }

  .comment-author {
    color: var(--text-primary);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .comment-date {
    font-family: var(--font-mono);
    color: var(--text-dim);
    font-size: 0.7rem;
    letter-spacing: 0.02em;
  }

  .comment-body {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .detail-layout {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .detail-left {
      order: 1;
    }

    .detail-right {
      order: 0;
    }

    .install-card {
      margin-top: 0;
    }
  }

  @media (max-width: 600px) {
    .detail-page {
      padding-top: calc(var(--nav-height) + 24px);
    }

    .detail-layout {
      gap: 20px;
    }

    .widget-name {
