---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Roadmap — MOLTamp">
  <Nav />
  <main class="roadmap-page">
    <div class="container">
      <div class="roadmap-hero fade-in">
        <span class="roadmap-badge">Roadmap</span>
        <h1>What's Coming</h1>
        <p>MOLTamp is under active development. Here's what we're building next.</p>
      </div>

      <div class="roadmap-grid">
        <div class="roadmap-card card fade-in" data-status="live">
          <div class="rc-status">Live</div>
          <div class="rc-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
          </div>
          <h3>Community Skins</h3>
          <p>Upload, browse, rate, and download skins from the community marketplace. MiniTerminal previews, color palettes, one-click install.</p>
        </div>

        <div class="roadmap-card card fade-in" data-status="live">
          <div class="rc-status">Live</div>
          <div class="rc-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3>Ratings</h3>
          <p>Rate community skins 1-5 stars. Discover the best skins by community score. Your ratings shape the gallery.</p>
        </div>

        <div class="roadmap-card card fade-in" data-status="next">
          <div class="rc-status">Next</div>
          <div class="rc-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Skin Builder</h3>
          <p>Visual skin editor in your browser. Pick colors, toggle effects, preview in real-time. Export as .zip with zero code.</p>
        </div>

        <div class="roadmap-card card fade-in" data-status="live">
          <div class="rc-status">Live</div>
          <div class="rc-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          </div>
          <h3>Custom Widgets</h3>
          <p>Build your own dashboard widgets with HTML and JavaScript. Weather, project stats, clocks, games. Sandboxed iframe SDK with live theme variables. Your cockpit, your data.</p>
        </div>

        <div class="roadmap-card card fade-in" data-status="planned">
          <div class="rc-status">Planned</div>
          <div class="rc-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
          </div>
          <h3>Custom Visualizers</h3>
          <p>Audio-reactive visualization engine. Create and share WebGL shader presets. Waveforms, particle systems, and spectral displays that pulse with your terminal.</p>
        </div>

        <div class="roadmap-card card fade-in" data-status="planned">
          <div class="rc-status">Planned</div>
          <div class="rc-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="M7 8h1m3 0h1m3 0h1"/></svg>
          </div>
          <h3>Windows & Linux</h3>
          <p>Native builds for Windows and Linux. Same skinnable cockpit experience on every platform.</p>
        </div>

        <div class="roadmap-card card fade-in" data-status="planned">
          <div class="rc-status">Planned</div>
          <div class="rc-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <h3>Plugin API</h3>
          <p>Extension system for power users. Hook into terminal events, shell state, and telemetry data. Build integrations that connect your tools to the cockpit.</p>
        </div>

        <div class="roadmap-card card fade-in" data-status="exploring">
          <div class="rc-status">Exploring</div>
          <div class="rc-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </div>
          <h3>Discord Community</h3>
          <p>Share setups, get notified about new skins, request features, and connect with other pilots. A home for the MOLTamp community.</p>
        </div>
      </div>

      <div class="roadmap-cta fade-in">
        <p>Want to shape the roadmap?</p>
        <a href="mailto:hello@moltamp.com" class="btn btn-primary">Send Feedback</a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .roadmap-page {
    padding: calc(var(--nav-height) + 60px) 0 100px;
  }

  .roadmap-hero {
    text-align: center;
    margin-bottom: 56px;
  }

  .roadmap-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: var(--accent-subtle);
    border: 1px solid var(--accent-glow);
    padding: 4px 14px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  .roadmap-hero h1 {
    font-family: var(--font-heading);
    font-weight: 800;
    font-style: italic;
    letter-spacing: -0.04em;
    line-height: 0.95;
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 12px;
  }

  .roadmap-hero p {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .roadmap-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 56px;
  }

  .roadmap-card {
    padding: 28px;
    position: relative;
    transition: transform var(--transition-fast), border-color var(--transition-fast);
  }

  .roadmap-card:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .rc-status {
    position: absolute;
    top: 16px;
    right: 16px;
    font-size: 0.68rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 10px;
    border-radius: 100px;
  }

  [data-status="live"] .rc-status {
    background: rgba(34, 197, 94, 0.12);
    color: #22c55e;
  }

  [data-status="building"] .rc-status {
    background: rgba(251, 191, 36, 0.12);
    color: #fbbf24;
  }

  [data-status="next"] .rc-status {
    background: rgba(59, 130, 246, 0.12);
    color: #3b82f6;
  }

  [data-status="planned"] .rc-status {
    background: rgba(168, 85, 247, 0.12);
    color: #a855f7;
  }

  [data-status="exploring"] .rc-status {
    background: rgba(148, 163, 184, 0.12);
    color: #94a3b8;
  }

  .rc-icon {
    margin-bottom: 14px;
    color: var(--text-dim);
  }

  [data-status="live"] .rc-icon { color: #22c55e; }
  [data-status="building"] .rc-icon { color: #fbbf24; }
  [data-status="next"] .rc-icon { color: #3b82f6; }
  [data-status="planned"] .rc-icon { color: #a855f7; }
  [data-status="exploring"] .rc-icon { color: #94a3b8; }

  .roadmap-card h3 {
    font-size: 1.1rem;
    margin-bottom: 8px;
  }

  .roadmap-card p {
    color: var(--text-secondary);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .roadmap-cta {
    text-align: center;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  .roadmap-cta p {
    color: var(--text-dim);
    font-size: 0.95rem;
    margin-bottom: 14px;
  }

  @media (max-width: 768px) {
    .roadmap-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
